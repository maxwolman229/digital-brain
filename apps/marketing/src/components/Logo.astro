---
const { dark = false } = Astro.props
---

<a
  href="/"
  aria-label="MD1 home"
  class:list={[
    'inline-flex border-[3px] px-2 pb-1 pt-0.5 text-[1.45rem] font-extrabold leading-none tracking-[0.01em]',
    dark ? 'border-[var(--md1-off-white)] text-[var(--md1-off-white)]' : 'border-[var(--md1-ink)] text-[var(--md1-ink)]',
  ]}
>
  M/D/1
</a>
